{
  "name": "runhaven-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run src/test",
    "test:e2e": "playwright test",
    "tauri": "tauri",
    "tauri:dev": "cd .. && ./ui/node_modules/.bin/tauri dev --config src-tauri/tauri.conf.json",
    "tauri:build": "cd .. && ./ui/node_modules/.bin/tauri build --config src-tauri/tauri.conf.json --debug --no-bundle"
  },
  "dependencies": {
    "@lucide/svelte": "1.20.0",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "svelte": "5.56.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tauri-apps/cli": "2.11.2",
    "svelte-check": "4.6.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
